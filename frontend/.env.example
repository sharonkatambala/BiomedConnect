# Copy to .env for local dev. On Vercel, set these in Project → Settings → Environment Variables.

# Public Supabase (browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production: full URL of your FastAPI app, including /api prefix (no trailing slash).
# Example: https://biomedconnect-api.onrender.com/api
# Local dev: leave unset to use Vite proxy /api → http://127.0.0.1:8000
VITE_API_BASE_URL=
